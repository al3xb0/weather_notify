# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://weather:weather@localhost:5432/weather_notify?schema=public"

# ── Auth (JWT) ────────────────────────────────────────────
# Secrets must be >= 32 chars and not start with "change-me" (validated at boot).
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET=""
JWT_REFRESH_TTL="7d"
# Refresh-cookie SameSite. Use "lax" when the API and UI share a site; use
# "none" (requires HTTPS) when the frontend is on a different domain (e.g. Vercel).
COOKIE_SAMESITE="lax"

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_URL="amqp://weather:weather@localhost:5672"
RABBITMQ_EXCHANGE="notifications"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
WEATHER_CACHE_TTL_SEC=600

# ── Watcher ───────────────────────────────────────────────
# Cron expression for the polling cycle (default: every 5 minutes)
WATCHER_CRON="0 */5 * * * *"

# ── Notification channels ─────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
# SMTP mailer — works with any free provider (Gmail, Brevo, Mailtrap, …).
# Leave SMTP_HOST empty to disable email (verification links are logged instead).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
MAIL_FROM="alerts@example.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:alerts@example.com"

# ── Notifier retry/DLQ ────────────────────────────────────
NOTIFIER_RETRY_DELAY_MS=30000
NOTIFIER_MAX_ATTEMPTS=3
NOTIFIER_PREFETCH=10

# ── App ───────────────────────────────────────────────────
NODE_ENV="development"
CORE_API_PORT=3000
# Comma-separated allow-list of front-end origins (no wildcard reflection).
CORS_ORIGIN="http://localhost:3001"
# Public URL of the frontend — used to build email verification links.
FRONT_URL="http://localhost:3001"
