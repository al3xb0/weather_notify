generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Metric {
  TEMPERATURE
  APPARENT_TEMP
  WIND_SPEED
  PRECIPITATION
  HUMIDITY
  SEVERE
}

enum Operator {
  GT
  GTE
  LT
  LTE
  EQ
}

enum Channel {
  TELEGRAM
  EMAIL
  WEB_PUSH
}

enum TriggerState {
  ARMED
  FIRED
}

enum ConditionLogic {
  AND
  OR
}

enum NotifStatus {
  SENT
  FAILED
}

enum Role {
  USER
  ADMIN
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  passwordHash     String
  role             Role               @default(USER)
  telegramChatId   String?
  telegramLinkToken String?           @unique
  telegramLinkTokenExpiresAt DateTime?
  quietHoursStart  String?
  quietHoursEnd    String?
  timezone         String?
  emailVerified    Boolean            @default(false)
  emailVerificationToken String?      @unique
  emailVerificationTokenExpiresAt DateTime?
  triggers         Trigger[]
  pushSubs         PushSubscription[]
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  pinnedCities     PinnedCity[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Trigger {
  id          String       @id @default(uuid())
  userId      String
  name        String
  city        String
  latitude    Float
  longitude   Float
  conditionLogic ConditionLogic @default(AND)
  conditions  TriggerCondition[]
  channels    Channel[]
  cooldownMin Int          @default(60)
  isActive    Boolean      @default(true)
  state       TriggerState @default(ARMED)
  lastFiredAt DateTime?
  lastEvaluatedAt   DateTime?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([isActive, latitude, longitude])
  @@index([userId])
}

model TriggerCondition {
  id        String   @id @default(uuid())
  triggerId String
  metric    Metric
  operator  Operator
  threshold Float
  order     Int      @default(0)
  lastObservedValue Float?
  lastMatched       Boolean?
  trigger   Trigger  @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  @@index([triggerId])
}

model Notification {
  id        String      @id @default(uuid())
  triggerId String
  userId    String
  channel   Channel
  status    NotifStatus
  payload   Json
  error     String?
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PinnedCity {
  id        String   @id @default(uuid())
  userId    String
  name      String
  country   String?
  admin1    String?
  latitude  Float
  longitude Float
  order     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, latitude, longitude])
  @@index([userId])
}
